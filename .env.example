# ── 基础环境（必填）─────────────────────────────────────────────
# 主平台登录地址
BASE_URL=https://your-main-platform.com/#/login
# 基础账号（无 marker 的用例默认使用）
USERNAME=your_username
PASSWORD=your_password

# ── 模块专用账号池（可选）──────────────────────────────────────
# 方式1（账号池，推荐）：并发时按 worker_id 轮询分配
#   MODULE_A_ACCOUNTS=user1:pass1,user2:pass2
# 方式2（单账号兼容）：
#   MODULE_A_USERNAME / MODULE_A_PASSWORD
# 优先级：账号池 > 单账号 > 基础账号
#
# 下方为示例模块（A / B / C），可按业务增删；
# 每新增 XXX_ACCOUNTS，conftest 会自动注册同名 pytest marker "xxx"。
MODULE_A_ACCOUNTS=module_a_user1:pass1,module_a_user2:pass2
MODULE_B_ACCOUNTS=module_b_user:pass
MODULE_C_ACCOUNTS=module_c_user:pass

# ── 企业微信机器人通知（可选）──────────────────────────────────
# 仅 runner.py 触发时推送，本地 pytest 调试不推送
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# ── 管理后台平台（数据验证用，可选）────────────────────────────
ADMIN_BASE_URL=https://your-admin-platform.com/#/login
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# ── 子系统平台（可选，复用主平台 BASE_URL 登录）────────────────
SUB_USERNAME=your_sub_username
SUB_PASSWORD=your_sub_password

# ── 数据库（数据验证用，可选）──────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
